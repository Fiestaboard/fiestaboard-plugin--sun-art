{
  "id": "sun_art",
  "name": "Sun Art",
  "version": "1.0.0",
  "description": "Display a full-screen sun art pattern that changes based on the sun's position throughout the day",
  "author": "FiestaBoard Team",
  "repository": "https://github.com/Fiestaboard/fiestaboard-plugin--sun-art",
  "documentation": "README.md",
  "icon": "sun",
  "category": "art",
  "min_refresh_seconds": 60,
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enable Sun Art",
        "default": false
      },
      "latitude": {
        "type": "number",
        "title": "Latitude",
        "description": "Location latitude for sun calculations (-90 to 90)",
        "minimum": -90,
        "maximum": 90
      },
      "longitude": {
        "type": "number",
        "title": "Longitude",
        "description": "Location longitude for sun calculations (-180 to 180)",
        "minimum": -180,
        "maximum": 180
      },
      "refresh_seconds": {
        "type": "integer",
        "title": "Refresh Interval (seconds)",
        "description": "How often to recalculate sun position and update pattern (minimum 60 seconds)",
        "default": 300,
        "minimum": 60
      }
    },
    "required": [
      "latitude",
      "longitude"
    ]
  },
  "env_vars": [
    {
      "name": "SUN_ART_ENABLED",
      "required": false,
      "description": "Enable sun art feature",
      "default": "false"
    },
    {
      "name": "SUN_ART_LATITUDE",
      "required": false,
      "description": "Location latitude (-90 to 90)"
    },
    {
      "name": "SUN_ART_LONGITUDE",
      "required": false,
      "description": "Location longitude (-180 to 180)"
    },
    {
      "name": "SUN_ART_REFRESH_SECONDS",
      "required": false,
      "description": "Refresh interval in seconds (default: 300)",
      "default": "300"
    }
  ],
  "variables": {
    "groups": {
      "display": {
        "label": "Display"
      },
      "sun": {
        "label": "Sun Position"
      }
    },
    "simple": {
      "sun_art": {
        "description": "Full sun art pattern for board display",
        "type": "string",
        "max_length": 200,
        "group": "display",
        "example": "(art pattern)"
      },
      "sun_stage": {
        "description": "Current sun stage name (e.g. sunrise, noon, sunset)",
        "type": "string",
        "max_length": 15,
        "group": "sun",
        "example": "noon"
      },
      "sun_position": {
        "description": "Sun elevation angle in degrees",
        "type": "number",
        "max_length": 6,
        "group": "sun",
        "example": "45.2"
      },
      "is_daytime": {
        "description": "Whether it is currently daytime (1 or 0)",
        "type": "boolean",
        "max_length": 1,
        "group": "sun",
        "example": "1"
      },
      "time_to_sunrise": {
        "description": "Time remaining until next sunrise",
        "type": "string",
        "max_length": 8,
        "group": "sun",
        "example": "5:23:10"
      },
      "time_to_sunset": {
        "description": "Time remaining until next sunset",
        "type": "string",
        "max_length": 8,
        "group": "sun",
        "example": "3:45:00"
      }
    }
  },
  "fiestaboard_version": ">=2.10.0",
  "screenshots": [
    {
      "src": "docs/board-display.png",
      "alt": "Sun Art displayed on a Vestaboard",
      "caption": "Display a full-screen sun art pattern that changes based on the sun's position throughout the day",
      "primary": true
    }
  ]
}
